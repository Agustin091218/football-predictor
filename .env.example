# ── Required ───────────────────────────────────────────────
# Free tier token from https://www.football-data.org/client/register
# Limit: 10 requests/minute on free plan
FOOTBALL_DATA_TOKEN=

# ── Optional: LLM analysis ────────────────────────────────
# Get a key from https://aistudio.google.com
# GEMINI_API_KEY=

# ── Paths ──────────────────────────────────────────────────
# SQLite database file (default: football.db)
# FOOTBALL_DB_PATH=football.db

# Directory for trained model artifacts (default: models)
# MODELS_DIR=models

# ELO ratings CSV file (default: archive/eloratings.csv)
# ELO_RATINGS_PATH=archive/eloratings.csv

# ── Ensemble weights ───────────────────────────────────────
# Weights must sum to 1.0. Higher = more influence.
# POISSON_WEIGHT=0.5
# XGBOOST_WEIGHT=0.5

# ── Monte Carlo ────────────────────────────────────────────
# Simulations per prediction (default: 10000)
# N_SIMULATIONS=10000

# ── Scheduler ──────────────────────────────────────────────
# Enable automatic fetch/stats/predict/retrain jobs (default: true)
# ENABLE_SCHEDULER=true

# ── Logging ────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Custom format (optional)
# LOG_FORMAT="%(asctime)s | %(levelname)-7s | %(name)s | %(message)s"
# LOG_DATEFMT=%Y-%m-%d %H:%M:%S

# ── API ────────────────────────────────────────────────────
# API host binding (default: 0.0.0.0)
# API_HOST=0.0.0.0

# API port (default: 8000)
# API_PORT=8000

# Optional API key for protected endpoints
# When set, all endpoints except /health require this header:
#   X-API-Key: <your-key>
# API_KEY=
